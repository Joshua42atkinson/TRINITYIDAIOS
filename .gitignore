# Trinity ID AI OS — .gitignore
# Clean repository for GitHub and institutional sharing

# ═══════════════════════════════════════════
# Build Artifacts
# ═══════════════════════════════════════════
/target/
**/target/
**/*.rs.bk
Cargo.lock
/build/
/dist/
*.so
*.dylib
*.dll

# ═══════════════════════════════════════════
# AI Model Files (too large for GitHub)
# ═══════════════════════════════════════════
*.gguf
*.onnx
*.safetensors
models/

# ═══════════════════════════════════════════
# Data (generated or downloaded at runtime)
# ═══════════════════════════════════════════
data/
/generated_assets/
/temp_assets/

# ═══════════════════════════════════════════
# Local Configuration & Secrets
# ═══════════════════════════════════════════
.local/
.env
.env.local
*.local
secrets/
config/local_*
trinity_key
trinity_key.pub
*.pem
*.key
id_rsa
id_ed25519

# ═══════════════════════════════════════════
# IDE & Editor Files
# ═══════════════════════════════════════════
.vscode/
.idea/
.windsurf/
.cursorrules
windsurf-config.json
*.swp
*.swo
*~

# ═══════════════════════════════════════════
# OS Generated Files
# ═══════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
nohup.out
*.pid

# ═══════════════════════════════════════════
# Local Development Artifacts
# ═══════════════════════════════════════════
*.log
*.tmp
*.bak
*.old
*.orig
*.rej
*.dump
*.prof
*.perf
verification_logs/
test_output/
scripts/local_*
tools/local_*

# ═══════════════════════════════════════════
# Development Databases
# ═══════════════════════════════════════════
*.db
*.sqlite
*.sqlite3

# ═══════════════════════════════════════════
# Node.js
# ═══════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ═══════════════════════════════════════════
# Python Environments
# ═══════════════════════════════════════════
**/.venv/
**/venv/
phi4_env/
trinity_ai_env/

# ═══════════════════════════════════════════
# Documentation Build
# ═══════════════════════════════════════════
docs/build/
docs/_build/

# ═══════════════════════════════════════════
# Media (demo recordings)
# ═══════════════════════════════════════════
*.mp4
*.webm
*.wav
*.mp3
recordings/
demo_videos/

# ═══════════════════════════════════════════
# Local Cache & Sandboxes
# ═══════════════════════════════════════════
.cache/
.cache-*/
FastFlowLM/
Phi-4-mini-reasoning-onnx-ryzenai-hybrid/
xdna-driver/
windsurf-conductor-mcp/

