  "workflowPhases": {
    "analysis": {
      "description": "Conduct comprehensive needs assessment and analysis",
      "tools": ["conduct_needs_assessment", "enhance_sme_interview", "target_audience_analysis"],
      "qualityChecks": ["qm_compliance_check", "ibstpi_compliance_check"],
      "deliverables": ["needs_assessment_report", "sme_interview_summary", "audience_analysis"]
    },
    "design": {
      "description": "Design learning objectives, assessments, and content structure",
      "tools": ["generate_learning_objectives", "create_assessment_strategy", "design_content_structure"],
      "qualityChecks": ["qm_compliance_check", "ibstpi_compliance_check", "accessibility_check"],
      "deliverables": ["learning_objectives", "assessment_strategy", "content_structure"]
    },
    "development": {
      "description": "Develop content, multimedia, and interactive elements",
      "tools": ["generate_content", "create_multimedia", "develop_interactive_elements"],
      "qualityChecks": ["qm_compliance_check", "accessibility_check"],
      "deliverables": ["course_content", "multimedia_assets", "interactive_activities"]
    },
    "implementation": {
      "description": "Deploy to LMS and setup analytics",
      "tools": ["deploy_to_lms", "setup_analytics", "create_learner_support"],
      "qualityChecks": ["qm_compliance_check"],
      "deliverables": ["lms_deployment", "analytics_dashboard", "learner_support_materials"]
    },
    "evaluation": {
      "description": "Conduct evaluation and generate reports",
      "tools": ["conduct_evaluation", "generate_report", "recommend_improvements"],
      "qualityChecks": ["qm_compliance_check"],
      "deliverables": ["evaluation_report", "improvement_recommendations", "effectiveness_analysis"]
    }
  },
