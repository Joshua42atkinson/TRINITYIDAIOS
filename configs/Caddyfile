# ═══════════════════════════════════════════════════════════
# TRINITY — Hardened Reverse Proxy (Red Hat Tier 1)
# ═══════════════════════════════════════════════════════════
#
# Red Hat Findings Addressed:
#   C1: Block /api/tools/* from public access
#   C2: Block /api/models/switch and /api/inference/* from public
#   C4: Block session/project/mutation routes
#   C6: Block shell/python execution paths
#   H1: Add security headers
#   H4: Block admin-style mutation routes
#   H5: Slim down health endpoint exposure
#
# Architecture:
#   Internet → Cloudflare Tunnel → Caddy (this file) → Trinity (127.0.0.1:3000)
#
# ═══════════════════════════════════════════════════════════

http://ldtatkinson.com, http://www.ldtatkinson.com {
    # ── Security Headers ──
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # ── BLOCKED: Truly dangerous routes (always blocked, even in prototype) ──

    # C1: Tool execution — hard blocker
    handle /api/tools* {
        respond "Forbidden" 403
    }

    # C2: Model/inference switching — hard blocker
    handle /api/models/switch {
        respond "Forbidden" 403
    }
    handle /api/inference/switch {
        respond "Forbidden" 403
    }
    handle /api/inference/refresh {
        respond "Forbidden" 403
    }

    # C4/C5: Session and project data — privacy
    handle /api/sessions* {
        respond "Forbidden" 403
    }
    handle /api/projects* {
        respond "Forbidden" 403
    }

    # C6: Shell/MCP execution
    handle /api/mcp {
        respond "Forbidden" 403
    }

    # Block ingest (document upload)
    handle /api/ingest {
        respond "Forbidden" 403
    }

    # Block WebSocket
    handle /ws {
        respond "Forbidden" 403
    }

    # ── ALLOWED: Prototype demo routes (edge_guard provides second defense layer) ──

    # All remaining API routes — forwarded to Trinity backend
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # Documentation — Four Chariots
    handle /docs/* {
        reverse_proxy localhost:3000
    }

    # Trinity — embedded engine UI
    handle /trinity/* {
        reverse_proxy localhost:3000
    }

    # Assets (images, fonts, etc.)
    handle /assets/* {
        reverse_proxy localhost:3000
    }

    # Frontend static files (React SPA) — the portfolio/landing page
    handle {
        reverse_proxy localhost:3000
    }
}

